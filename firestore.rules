rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasRole(role) {
      return isSignedIn() && (
        request.auth.token.role == role ||
        userRole() == role
      );
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isBroadcaster() {
      return hasRole('broadcaster');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isStreamOwner(streamData) {
      return isSignedIn() && streamData.broadcasterUid == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /streams/{streamId} {
      allow read: if isSignedIn();
      allow create: if isBroadcaster() || isAdmin();
      allow update: if isAdmin() || (
        isStreamOwner(resource.data)
      );
      allow delete: if isAdmin() || (
        isStreamOwner(resource.data)
      );
    }

    match /analytics/{analyticsId} {
      allow read: if isAdmin() || (
        isBroadcaster() &&
        get(/databases/$(database)/documents/streams/$(analyticsId)).data.broadcasterUid == request.auth.uid
      );
      allow write: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || isBroadcaster();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
