# ── Shared — all services need these ─────────────────────────────────
GCP_PROJECT_ID=sports-stream-66553
FIREBASE_CREDENTIALS=./sports-stream-66553-firebase-adminsdk-fbsvc-f2d245e286.json
ENV=development
ADMIN_PANEL_USERNAME=admin
ADMIN_PANEL_PASSWORD=Admin@123
ADMIN_PANEL_SESSION_SECRET=change-me-with-32-or-more-characters

# ── Stream service ────────────────────────────────────────────────────
GCS_BUCKET=sports-stream-66553.appspot.com
CDN_BASE_URL=https://storage.googleapis.com/sports-stream-66553.appspot.com
TRANSCODER_LOCATION=europe-west1

# ── Analytics service ─────────────────────────────────────────────────
METRICS_PORT=9090
VIEWER_SUB=viewer-events-analytics-sub
STREAM_SUB=stream-events-analytics-sub

# ── Notification service ──────────────────────────────────────────────
NOTIFICATION_SUB=notification-events-sub