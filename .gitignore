# ══════════════════════════════════════════════════════
# Sports Stream Backend — .gitignore
# ══════════════════════════════════════════════════════

# ── Credentials & Secrets ─────────────────────────────
.env
.env.*
.env.local
.env.development
.env.production
.env.staging

# Firebase / GCP service account keys
*.json
!package.json
!package-lock.json
*firebase-adminsdk*.json
*service-account*.json
*sa-key*.json
key.json
credentials.json

# ── Go ────────────────────────────────────────────────
# Compiled binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary
*.test

# Go build output
/bin/
/dist/
/tmp/

# Go coverage
*.out
coverage.html

# Go workspace
go.work
go.work.sum

# ── Docker ────────────────────────────────────────────
.dockerignore.bak

# ── IDE / Editor ──────────────────────────────────────
# JetBrains (GoLand)
.idea/
*.iml
*.iws
*.ipr
.idea_modules/

# VS Code
.vscode/
*.code-workspace

# Vim
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Logs ──────────────────────────────────────────────
*.log
logs/
log/

# ── Build artifacts ───────────────────────────────────
/bin/
build/
dist/
out/

# ── Test results ──────────────────────────────────────
test-results.txt
test-results/
coverage/
*.coverprofile

# ── Terraform ─────────────────────────────────────────
**/.terraform/
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform.lock.hcl
terraform.tfvars
*.auto.tfvars

# ── Kubernetes ────────────────────────────────────────
# (kept for reference but not deployed — using Cloud Run)
kubeconfig
*.kubeconfig

# ── Local scripts ─────────────────────────────────────
scripts/local/
*.local.sh

# ── HLS / Media (local testing) ───────────────────────
/tmp/hls/
*.m3u8
*.ts
*.mp4
*.mov

# ── Misc ──────────────────────────────────────────────
*.bak
*.tmp
*.cache
.cache/
vendor/