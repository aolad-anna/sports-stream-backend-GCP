# Shared
GCP_PROJECT_ID=your-gcp-project-id
FIREBASE_CREDENTIALS=./secrets/firebase-adminsdk.json
ENV=development

# Admin panel
ADMIN_PANEL_USERNAME=admin
ADMIN_PANEL_PASSWORD=change-me-admin-password
ADMIN_PANEL_SESSION_SECRET=change-me-with-32-or-more-characters

# Stream service
GCS_BUCKET=your-bucket.appspot.com
CDN_BASE_URL=https://storage.googleapis.com/your-bucket.appspot.com

# Analytics service
METRICS_PORT=9090
VIEWER_SUB=viewer-events-analytics-sub
STREAM_SUB=stream-events-analytics-sub

# Notification service
NOTIFICATION_SUB=notification-events-sub

# Pre-scaler
K8S_NAMESPACE=production
STREAM_DEPLOYMENT=stream-service
